# --- Public site config ---
# Used for canonical URL, OG tags, robots/sitemap. Defaults to https://pinka.finance.
NEXT_PUBLIC_SITE_URL="https://pinka.finance"

# --- Runtime secrets live in the Cloudflare Worker, not here ---
# The landing is a static export; waitlist/newsletter signups are handled by the
# Worker (worker/index.js) writing to a D1 database. Configure these as Worker
# secrets, NOT as build-time env vars:
#
#   wrangler secret put RESEND_API_KEY        # optional — enables confirmation emails
#   wrangler secret put WAITLIST_NOTIFY_EMAIL # optional — admin signup notifications
#
# RESEND_FROM (e.g. "pinka <hello@pinka.finance>") can be set under [vars] in wrangler.toml.
