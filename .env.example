# --- Public site config ---
NEXT_PUBLIC_SITE_URL="https://pinka.finance"

# --- Database (Postgres) ---
# Local dev: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
# or use a free Neon/Supabase instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pinka?schema=public"

# --- Resend transactional email ---
# Get a key at https://resend.com. In dev, leave blank to log emails to stdout instead of sending.
RESEND_API_KEY=""
RESEND_FROM="pinka <hello@pinka.finance>"

# --- Optional: server admin notification when someone signs up ---
WAITLIST_NOTIFY_EMAIL=""

# --- Self-host (docker-compose / Coolify) only ---
# Used by docker-compose.yml to provision Postgres and build DATABASE_URL.
# Generate a strong value with: openssl rand -base64 32
POSTGRES_PASSWORD=""
